<UserControl x:Class="TestApp.Desktop.Views.DeckListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Grid principal con z-index para capas -->
    <Grid>
        <!-- Contenido principal -->
        <Grid Margin="20" IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverseConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Deck List -->
            <Border Grid.Column="0" Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Mis Mazos" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                    <!-- Create new deck -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox Text="{Binding NewDeckName, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="200" Padding="8" VerticalContentAlignment="Center"/>
                        <Button Content="➕ Crear Mazo" Margin="10,0,0,0" Padding="10,8"
                                Command="{Binding CreateDeckCommand}"/>
                    </StackPanel>

                    <!-- Deck list -->
                    <ListBox ItemsSource="{Binding Decks}" 
                             SelectedItem="{Binding SelectedDeck}"
                             Height="350" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="5" Padding="10" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding Files.Count, StringFormat='{}{0} archivos'}" 
                                                       Foreground="Gray" FontSize="12"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="🗑️" 
                                                Command="{Binding DataContext.DeleteDeckCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Right Panel: Deck Details -->
            <Border Grid.Column="1" Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                <Grid>
                    <!-- Main Deck Details -->
                    <StackPanel Visibility="{Binding ShowQuestionList, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                        <TextBlock Text="Detalles del Mazo" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <StackPanel Visibility="{Binding SelectedDeck, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding SelectedDeck.Name}" FontSize="16" FontWeight="SemiBold"/>

                            <!-- PDF Import Section -->
                            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                <TextBlock Text="Nº preguntas:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding PdfQuestionCount, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="60" Padding="8" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                <Button Content="📁 Importar PDF" Margin="10,0,0,0" Padding="15,10"
                                        Command="{Binding ImportFileCommand}"/>
                            </StackPanel>

                            <TextBlock Text="Archivos:" FontWeight="SemiBold" Margin="0,20,0,10"/>
                            <ListBox ItemsSource="{Binding SelectedDeckFiles}" Height="200" BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="5" Padding="10" Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Questions.Count, StringFormat='{}{0} preguntas'}" 
                                                               Foreground="Gray" FontSize="12"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="▶️" ToolTip="Iniciar examen"
                                                        Command="{Binding DataContext.ShowExamOptionsDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" FontSize="14" Margin="5,0"/>
                                                <Button Grid.Column="2" Content="👁️" ToolTip="Ver preguntas"
                                                        Command="{Binding DataContext.ShowFileQuestionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" FontSize="14" Margin="5,0"/>
                                                <Button Grid.Column="3" Content="🗑️" ToolTip="Eliminar archivo"
                                                        Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Content="🎯 Iniciar Examen del Mazo" Margin="0,20,0,0" Padding="20,12"
                                    FontSize="14" FontWeight="Bold" Background="#4CAF50" Foreground="White"
                                    HorizontalAlignment="Left"
                                    Command="{Binding StartDeckExamCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Question List Panel -->
                    <Grid Visibility="{Binding ShowQuestionList, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Row="0" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SelectedFile.Name, StringFormat='Preguntas: {0}'}" FontSize="18" FontWeight="Bold"/>
                            <Button Grid.Column="1" Padding="10,5" Margin="0,0,10,0"
                                    Command="{Binding ToggleEditModeCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content" Value="✏️ Editar"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Content" Value="👁️ Solo ver"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="2" Content="✖️ Cerrar" Padding="10,5"
                                    Command="{Binding CloseQuestionListCommand}"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding QuestionsToShow}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Question.Number, StringFormat='Pregunta {0}'}" 
                                                           FontWeight="Bold" FontSize="12" Foreground="#666"/>
                                                <TextBlock Text="{Binding Question.Statement}" TextWrapping="Wrap" Margin="0,5,0,8"/>
                                                <StackPanel Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Question.OptionA, StringFormat='A) {0}'}" TextWrapping="Wrap" Margin="0,2"
                                                               Foreground="{Binding Question.CorrectAnswer, Converter={StaticResource CorrectAnswerColorConverter}, ConverterParameter=A}"/>
                                                    <TextBlock Text="{Binding Question.OptionB, StringFormat='B) {0}'}" TextWrapping="Wrap" Margin="0,2"
                                                               Foreground="{Binding Question.CorrectAnswer, Converter={StaticResource CorrectAnswerColorConverter}, ConverterParameter=B}"/>
                                                    <TextBlock Text="{Binding Question.OptionC, StringFormat='C) {0}'}" TextWrapping="Wrap" Margin="0,2"
                                                               Foreground="{Binding Question.CorrectAnswer, Converter={StaticResource CorrectAnswerColorConverter}, ConverterParameter=C}"/>
                                                    <TextBlock Text="{Binding Question.OptionD, StringFormat='D) {0}'}" TextWrapping="Wrap" Margin="0,2"
                                                               Foreground="{Binding Question.CorrectAnswer, Converter={StaticResource CorrectAnswerColorConverter}, ConverterParameter=D}"/>
                                                </StackPanel>
                                                
                                                <!-- Edit Mode: Cambiar respuesta correcta -->
                                                <Border Background="#FFF3E0" CornerRadius="5" Padding="10" Margin="0,10,0,0"
                                                        Visibility="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Text="Cambiar respuesta correcta:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <RadioButton Content="A" GroupName="{Binding Question.Id}" Margin="0,0,15,0"
                                                                         IsChecked="{Binding SelectedAnswer, Converter={StaticResource CharToBoolConverter}, ConverterParameter=A}"/>
                                                            <RadioButton Content="B" GroupName="{Binding Question.Id}" Margin="0,0,15,0"
                                                                         IsChecked="{Binding SelectedAnswer, Converter={StaticResource CharToBoolConverter}, ConverterParameter=B}"/>
                                                            <RadioButton Content="C" GroupName="{Binding Question.Id}" Margin="0,0,15,0"
                                                                         IsChecked="{Binding SelectedAnswer, Converter={StaticResource CharToBoolConverter}, ConverterParameter=C}"/>
                                                            <RadioButton Content="D" GroupName="{Binding Question.Id}" Margin="0,0,15,0"
                                                                         IsChecked="{Binding SelectedAnswer, Converter={StaticResource CharToBoolConverter}, ConverterParameter=D}"/>
                                                            <Button Content="💾 Guardar" Padding="10,3"
                                                                    Command="{Binding DataContext.SaveCorrectAnswerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                
                                                <TextBlock Text="{Binding Question.Source, StringFormat='📚 Fuente: {0}'}" 
                                                           FontStyle="Italic" Foreground="#666" Margin="0,8,0,0"
                                                           Visibility="{Binding Question.Source, Converter={StaticResource NullToVisibilityConverter}}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Background="#CC000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" CornerRadius="10" Padding="30"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="{Binding LoadingMessage}" FontSize="16" FontWeight="SemiBold" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Fondo semitransparente para diálogo de opciones de examen -->
        <Border Background="#80000000"
                Visibility="{Binding ShowExamOptions, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" CornerRadius="10" Padding="25"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel MinWidth="350">
                    <TextBlock Text="⚙️ Opciones del Examen" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="{Binding ExamTargetFile.Name}" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <CheckBox Content="🔀 Preguntas en orden aleatorio" Margin="0,0,0,10"
                              IsChecked="{Binding RandomQuestions}"/>
                    
                    <CheckBox Content="🎲 Respuestas en orden aleatorio" Margin="0,0,0,10"
                              IsChecked="{Binding RandomAnswers}"/>
                    
                    <CheckBox Margin="0,0,0,20" IsChecked="{Binding ReviewMode}">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📖 Modo revisión"/>
                                <TextBlock Text=" ❓" Foreground="#2196F3" FontWeight="Bold" Cursor="Help">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="300">
                                                <TextBlock Text="Modo Revisión (activado):" FontWeight="Bold" Margin="0,0,0,5"/>
                                                <TextBlock Text="Verás la respuesta correcta después de cada pregunta." TextWrapping="Wrap"/>
                                                <TextBlock Text=" " />
                                                <TextBlock Text="Modo Examen Final (desactivado):" FontWeight="Bold" Margin="0,5,0,5"/>
                                                <TextBlock Text="Las respuestas se mostrarán solo al finalizar el examen completo." TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Padding="15,8" Margin="0,0,10,0"
                                Command="{Binding CancelExamOptionsCommand}"/>
                        <Button Content="▶️ Iniciar" Padding="15,8" 
                                Background="#4CAF50" Foreground="White"
                                Command="{Binding StartExamWithOptionsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Diálogo de advertencia (detectadas MENOS preguntas) -->
        <Border Background="#80000000"
                Visibility="{Binding ShowPdfWarningDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" CornerRadius="10" Padding="25"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="450">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="ℹ️ Aviso de Importación" 
                               FontSize="16" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,15"/>
                    
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,15">
                        <Run Text="Archivo: "/>
                        <Run Text="{Binding PendingPdfFileName, Mode=OneWay}"/>
                        <Run Text=".pdf"/>
                    </TextBlock>
                    
                    <Border Background="#E3F2FD" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                        <TextBlock Text="{Binding WarningMessage}" TextWrapping="Wrap" 
                                   Foreground="#1976D2" FontSize="13"/>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Padding="15,8" Margin="0,0,10,0"
                                Command="{Binding CancelWarningCommand}"/>
                        <Button Content="✅ Aceptar e Importar" Padding="15,8" 
                                Background="#4CAF50" Foreground="White"
                                Command="{Binding AcceptWarningAndImportCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Diálogo de discrepancia (detectadas MÁS preguntas) -->
        <Border Background="#80000000"
                Visibility="{Binding ShowPdfMismatchDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" CornerRadius="10" Padding="25"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel MinWidth="400">
                    <TextBlock Text="⚠️ Discrepancia en número de preguntas" 
                               FontSize="16" FontWeight="Bold" Foreground="#F57C00" Margin="0,0,0,15"/>
                    
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,15">
                        <Run Text="Archivo: "/>
                        <Run Text="{Binding PendingPdfFileName, Mode=OneWay}"/>
                        <Run Text=".pdf"/>
                    </TextBlock>
                    
                    <Border Background="#FFF3E0" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Configuradas: " Foreground="#666"/>
                                <TextBlock Text="{Binding PdfQuestionCount}" FontWeight="Bold"/>
                                <TextBlock Text=" preguntas" Foreground="#666"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Detectadas: " Foreground="#666"/>
                                <TextBlock Text="{Binding PdfDetectedQuestions}" FontWeight="Bold" Foreground="#4CAF50"/>
                                <TextBlock Text=" preguntas" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Text="¿Cuántas preguntas deseas importar?" Margin="0,0,0,15" FontWeight="SemiBold"/>
                    
                    <StackPanel>
                        <Button Padding="12,10" Margin="0,0,0,8"
                                HorizontalContentAlignment="Left"
                                Command="{Binding ImportDetectedQuestionsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📥 Importar " />
                                <TextBlock Text="{Binding PdfDetectedQuestions}" FontWeight="Bold"/>
                                <TextBlock Text=" (todas las detectadas)"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Padding="12,10" Margin="0,0,0,8"
                                HorizontalContentAlignment="Left"
                                Command="{Binding ImportConfiguredQuestionsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 Importar solo "/>
                                <TextBlock Text="{Binding PdfQuestionCount}" FontWeight="Bold"/>
                                <TextBlock Text=" (las configuradas)"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Content="❌ Cancelar" Padding="12,10"
                                HorizontalContentAlignment="Left"
                                Command="{Binding CancelPdfImportCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Diálogo de confirmación de borrado de mazo -->
        <Border Background="#80000000"
                Visibility="{Binding ShowDeleteDeckDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" CornerRadius="10" Padding="25"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="450">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="⚠️ Confirmar Eliminación" 
                               FontSize="16" FontWeight="Bold" Foreground="#F44336" Margin="0,0,0,15"/>
                    
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,10">
                        <Run Text="¿Estás seguro de que deseas eliminar el mazo "/>
                        <Run Text="{Binding DeckToDelete.Name, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text="?"/>
                    </TextBlock>
                    
                    <Border Background="#FFEBEE" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Foreground="#C62828" FontSize="13" Margin="0,0,0,8">
                                <Run Text="Este mazo contiene "/>
                                <Run Text="{Binding DeckToDelete.Files.Count, Mode=OneWay}" FontWeight="Bold"/>
                                <Run Text=" archivo(s) con todas sus preguntas."/>
                            </TextBlock>
                            <TextBlock Text="Esta acción no se puede deshacer." 
                                       TextWrapping="Wrap" Foreground="#C62828" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Padding="15,8" Margin="0,0,10,0"
                                Command="{Binding CancelDeleteDeckCommand}"/>
                        <Button Content="🗑️ Eliminar" Padding="15,8" 
                                Background="#F44336" Foreground="White"
                                Command="{Binding ConfirmDeleteDeckCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Diálogo de opciones del examen del mazo -->
        <Border Background="#80000000"
                Visibility="{Binding ShowDeckExamOptions, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" CornerRadius="10" Padding="25"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel MinWidth="350">
                    <TextBlock Text="⚙️ Opciones del Examen del Mazo" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,15">
                        <Run Text="Mazo: "/>
                        <Run Text="{Binding SelectedDeck.Name, Mode=OneWay}"/>
                    </TextBlock>
                    
                    <Border Background="#E8F5E9" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                        <TextBlock>
                            <Run Text="Total de preguntas disponibles: "/>
                            <Run Text="{Binding SelectedDeckFiles, Converter={StaticResource CountToStringConverter}, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                    </Border>
                    
                    <TextBlock Text="Número de preguntas del examen:" Margin="0,0,0,8" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding DeckExamQuestionCount, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10" Margin="0,0,0,15" FontSize="14"
                             HorizontalContentAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox Content="🔀 Preguntas aleatorias" IsChecked="True" IsEnabled="False"/>
                        <TextBlock Text=" ℹ️" Foreground="#9E9E9E" VerticalAlignment="Center" Cursor="Help"
                                   ToolTip="En el examen del mazo, las preguntas siempre se mezclan de todos los archivos"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox Content="🎲 Respuestas aleatorias" IsChecked="True" IsEnabled="False"/>
                        <TextBlock Text=" ℹ️" Foreground="#9E9E9E" VerticalAlignment="Center" Cursor="Help"
                                   ToolTip="En el examen del mazo, las respuestas siempre se barajan para mayor dificultad"/>
                    </StackPanel>
                    
                    <CheckBox Margin="0,0,0,20" IsChecked="{Binding DeckExamReviewMode}">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📖 Modo revisión"/>
                                <TextBlock Text=" ❓" Foreground="#2196F3" FontWeight="Bold" Cursor="Help">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="300">
                                                <TextBlock Text="Modo Revisión (activado):" FontWeight="Bold" Margin="0,0,0,5"/>
                                                <TextBlock Text="Verás la respuesta correcta después de cada pregunta." TextWrapping="Wrap"/>
                                                <TextBlock Text=" " />
                                                <TextBlock Text="Modo Examen Final (desactivado):" FontWeight="Bold" Margin="0,5,0,5"/>
                                                <TextBlock Text="Las respuestas se mostrarán solo al finalizar el examen completo." TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Padding="15,8" Margin="0,0,10,0"
                                Command="{Binding CancelDeckExamOptionsCommand}"/>
                        <Button Content="▶️ Iniciar Examen" Padding="15,8" 
                                Background="#4CAF50" Foreground="White"
                                Command="{Binding StartDeckExamWithOptionsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>