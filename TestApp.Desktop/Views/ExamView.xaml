<UserControl x:Class="TestApp.Desktop.Views.ExamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <!-- Exam in progress -->
            <Border Background="#F5F5F5" CornerRadius="10" Padding="30"
                    Visibility="{Binding ExamFinished, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                <StackPanel MaxWidth="700">
                    <!-- Progress -->
                    <TextBlock Text="{Binding ProgressText}" FontSize="14" Foreground="Gray" Margin="0,0,0,10"/>
                    <ProgressBar Value="{Binding TotalAnswered}" Maximum="{Binding QuestionsCount}" Height="8" Margin="0,0,0,20"/>

                    <!-- Question - Usar DisplayNumber en lugar de CurrentQuestion.Number -->
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayQuestion.DisplayNumber, StringFormat='Pregunta {0}'}" 
                                       FontWeight="Bold" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding DisplayQuestion.Statement}" 
                                       FontSize="16" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Options -->
                    <StackPanel>
                        <RadioButton GroupName="Answer" Margin="0,4" 
                                     IsChecked="{Binding IsOptionASelected, Mode=TwoWay}"
                                     IsEnabled="{Binding ShowResult, Converter={StaticResource BoolInverseConverter}}"
                                     VerticalContentAlignment="Center">
                            <Border Padding="12,10" Background="White" CornerRadius="5" MinWidth="500">
                                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                    <Run Text="A) " FontWeight="Bold"/>
                                    <Run Text="{Binding DisplayQuestion.OptionA, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </RadioButton>
                        <RadioButton GroupName="Answer" Margin="0,4"
                                     IsChecked="{Binding IsOptionBSelected, Mode=TwoWay}"
                                     IsEnabled="{Binding ShowResult, Converter={StaticResource BoolInverseConverter}}"
                                     VerticalContentAlignment="Center">
                            <Border Padding="12,10" Background="White" CornerRadius="5" MinWidth="500">
                                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                    <Run Text="B) " FontWeight="Bold"/>
                                    <Run Text="{Binding DisplayQuestion.OptionB, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </RadioButton>
                        <RadioButton GroupName="Answer" Margin="0,4"
                                     IsChecked="{Binding IsOptionCSelected, Mode=TwoWay}"
                                     IsEnabled="{Binding ShowResult, Converter={StaticResource BoolInverseConverter}}"
                                     VerticalContentAlignment="Center">
                            <Border Padding="12,10" Background="White" CornerRadius="5" MinWidth="500">
                                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                    <Run Text="C) " FontWeight="Bold"/>
                                    <Run Text="{Binding DisplayQuestion.OptionC, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </RadioButton>
                        <RadioButton GroupName="Answer" Margin="0,4"
                                     IsChecked="{Binding IsOptionDSelected, Mode=TwoWay}"
                                     IsEnabled="{Binding ShowResult, Converter={StaticResource BoolInverseConverter}}"
                                     VerticalContentAlignment="Center">
                            <Border Padding="12,10" Background="White" CornerRadius="5" MinWidth="500">
                                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                    <Run Text="D) " FontWeight="Bold"/>
                                    <Run Text="{Binding DisplayQuestion.OptionD, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </RadioButton>
                    </StackPanel>

                    <!-- Result feedback -->
                    <Border Margin="0,20,0,0" Padding="15" CornerRadius="5"
                            Visibility="{Binding ShowResult, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                        <Setter Property="Background" Value="#C8E6C9"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                        <Setter Property="Background" Value="#FFCDD2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock FontWeight="Bold" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                <Setter Property="Text" Value="✅ ¡Correcto!"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                <Setter Property="Text" Value="❌ Incorrecto"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding DisplayCorrectAnswer, StringFormat='La respuesta correcta es: {0}'}" 
                                       Margin="0,5,0,0" TextWrapping="Wrap"
                                       Visibility="{Binding IsCorrect, Converter={StaticResource BoolToVisibilityInverseConverter}}"/>
                            <TextBlock Text="{Binding DisplayQuestion.Source, StringFormat='Fuente: {0}'}" 
                                       Margin="0,10,0,0" FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap"
                                       Visibility="{Binding DisplayQuestion.Source, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,20">
                        <Button Content="Confirmar" Padding="20,10" FontSize="14"
                                Command="{Binding ConfirmAnswerCommand}"
                                Visibility="{Binding ShowResult, Converter={StaticResource BoolToVisibilityInverseConverter}}"
                                IsEnabled="{Binding SelectedAnswer, Converter={StaticResource NullToBoolConverter}}"/>
                        <Button Content="Siguiente ➡️" Padding="20,10" FontSize="14"
                                Command="{Binding NextQuestionCommand}"
                                Visibility="{Binding ShowResult, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Exam finished -->
            <Border Background="#F5F5F5" CornerRadius="10" Padding="40"
                    Visibility="{Binding ExamFinished, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <!-- Results Panel -->
                    <StackPanel HorizontalAlignment="Center"
                                Visibility="{Binding ShowReviewMode, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                        <TextBlock Text="🎉 ¡Examen Completado!" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultText}" FontSize="20" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding PercentageText}" FontSize="16" Foreground="Gray" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                        <!-- Action Buttons -->
                        <StackPanel Margin="0,30,0,20" HorizontalAlignment="Center">
                            <Button Content="📋 Repasar todas las preguntas" Padding="20,12" FontSize="14" 
                                    Margin="0,0,0,10" MinWidth="280"
                                    Command="{Binding ReviewAllQuestionsCommand}"/>
                        
                            <Button Padding="20,12" FontSize="14" Margin="0,0,0,10" MinWidth="280"
                                    Background="#FF9800" Foreground="White"
                                    Command="{Binding RetryFailedQuestionsCommand}"
                                    Visibility="{Binding HasFailedQuestions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button.Content>
                                    <TextBlock>
                                        <Run Text="🔄 Repetir falladas ("/>
                                        <Run Text="{Binding FailedCount, Mode=OneWay}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                            
                            <Button Content="🏠 Volver al Inicio" Padding="20,12" FontSize="14"
                                    Command="{Binding GoHomeCommand}" MinWidth="280"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Review Panel - Usar DisplayNumber -->
                    <Grid Visibility="{Binding ShowReviewMode, Converter={StaticResource BoolToVisibilityConverter}}"
                          MinWidth="600" MaxWidth="800">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MaxHeight="400"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📋 Repaso del Examen" FontSize="20" FontWeight="Bold" 
                                   Margin="0,0,0,15" HorizontalAlignment="Center"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ReviewQuestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="5" Padding="12" Margin="0,0,0,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#C8E6C9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                            <Setter Property="Background" Value="#FFCDD2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Grid>
                                                    <!-- Mostrar DisplayNumber en lugar de Question.Number -->
                                                    <TextBlock Text="{Binding DisplayNumber, StringFormat='Pregunta {0}'}" 
                                                               FontWeight="Bold" FontSize="12" Foreground="#666"/>
                                                    <TextBlock HorizontalAlignment="Right" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="✅"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                        <Setter Property="Text" Value="❌"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                                <TextBlock Text="{Binding Question.Statement}" TextWrapping="Wrap" Margin="0,5,0,8"/>
                                                <StackPanel Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Question.OptionA, StringFormat='A) {0}'}" TextWrapping="Wrap" Margin="0,2"
                                                               Foreground="{Binding Question.CorrectAnswer, Converter={StaticResource CorrectAnswerColorConverter}, ConverterParameter=A}"/>
                                                    <TextBlock Text="{Binding Question.OptionB, StringFormat='B) {0}'}" TextWrapping="Wrap" Margin="0,2"
                                                               Foreground="{Binding Question.CorrectAnswer, Converter={StaticResource CorrectAnswerColorConverter}, ConverterParameter=B}"/>
                                                    <TextBlock Text="{Binding Question.OptionC, StringFormat='C) {0}'}" TextWrapping="Wrap" Margin="0,2"
                                                               Foreground="{Binding Question.CorrectAnswer, Converter={StaticResource CorrectAnswerColorConverter}, ConverterParameter=C}"/>
                                                    <TextBlock Text="{Binding Question.OptionD, StringFormat='D) {0}'}" TextWrapping="Wrap" Margin="0,2"
                                                               Foreground="{Binding Question.CorrectAnswer, Converter={StaticResource CorrectAnswerColorConverter}, ConverterParameter=D}"/>
                                                </StackPanel>
                                                <TextBlock Margin="0,8,0,0" FontStyle="Italic" Foreground="#666"
                                                           Visibility="{Binding IsCorrect, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                                                    <Run Text="Tu respuesta: "/>
                                                    <Run Text="{Binding UserAnswer, Mode=OneWay}" FontWeight="Bold"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Question.Source, StringFormat='📚 Fuente: {0}'}" 
                                                           FontStyle="Italic" Foreground="#666" Margin="0,4,0,0"
                                                           Visibility="{Binding Question.Source, Converter={StaticResource NullToVisibilityConverter}}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Button Grid.Row="2" Content="⬅️ Volver a resultados" Padding="20,12" FontSize="14"
                                Margin="0,15,0,20" HorizontalAlignment="Center"
                                Command="{Binding CloseReviewCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>